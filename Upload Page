{% extends 'base.html' %}

{% block content %}

<div class="max-w-xl mx-auto bg-white rounded-xl shadow p-8">

<h2 class="text-3xl font-bold mb-4">
Upload Resume
</h2>

<form
method="POST"
enctype="multipart/form-data">

<input
type="file"
name="resume"
accept=".pdf"
class="mb-4">

<button
class="bg-indigo-600 text-white px-6 py-3 rounded">
Analyze Resume
</button>

</form>

</div>

{% endblock %}
